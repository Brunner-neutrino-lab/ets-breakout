		)
		(uuid "b9ab32e3-064b-4efc-a144-b855658c5076")
	)
	(text "Description is with respect to ch1 block component references\n========================================\n\n* Q1-S is biased to ~ +5V by Mux_Bias.\n* When SiPM bias is not powered, R32 pulls Q1-G to GND. \n* When SiPM bias is powered positive, R2 pulls Q1-G to MUX_BIAS \n  (plus D7 diode drop).\n* Pulse_Common is biased to Mux_Bias in root schematic\n\n* R5 and C2 are chosen to ensure that the pulse does not \n  exceed too high a level and get choked by Q1. They may\n  not be needed.\n\n"
		(exclude_from_sim no)
		(at -375.285 107.315 0)
		(effects
			(font
				(size 2 2)
			)
			(justify left bottom)
		)
		(uuid "cf59a637-1096-46e5-9ae4-350a99d72712")
	)
	(text "Leakage through relay"
		(exclude_from_sim no)
		(at 18.288 171.196 0)
