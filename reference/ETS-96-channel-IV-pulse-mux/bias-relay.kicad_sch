	(text "MCX is smaller than SMA, 0.2\" square hole pattern\ne.g. https://www.te.com/commerce/DocumentDelivery/DDEController?Action=srchrtrv&DocNm=1060984-1&DocType=Customer+Drawing&DocLang=English\nspecifies 1.3mm hole diameter\n\nTE Connectivity AMP 1060984-1; there may be cheaper ones but the\nfootprint will probably be the same"
		(exclude_from_sim no)
		(at -375.031 275.844 0)
		(effects
			(font
				(size 3.81 3.81)
			)
			(justify left bottom)
		)
		(uuid "94c33ecc-0128-40b9-b3ed-9047eb1f32cc")
	)
	(text "TLP170J: Voff = 600V, Ron = 60\nTLP3149: Voff = 100V, Ron 0.2"
